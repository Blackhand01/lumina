{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumina.local/schemas/experiment-log.schema.json",
  "title": "Lumina Experiment Log",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "run_id",
    "timestamp",
    "model",
    "backend",
    "quantization",
    "prompt_tokens",
    "generated_tokens",
    "cache_policy",
    "peak_memory_mb",
    "swap_mb",
    "memory_pressure",
    "compressed_memory_mb",
    "latency_ms_per_token",
    "tokens_per_second",
    "benchmark",
    "score",
    "notes"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for a single experiment run."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Run start time in ISO 8601 format."
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "backend": {
      "type": "string",
      "minLength": 1,
      "examples": ["mlx", "llama.cpp", "transformers"]
    },
    "quantization": {
      "type": "string",
      "minLength": 1,
      "examples": ["none", "q4", "q5", "q8"]
    },
    "prompt_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "generated_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "cache_policy": {
      "type": "string",
      "minLength": 1,
      "description": "Policy used for KV cache, prompt cache, disk cache, or model cache."
    },
    "peak_memory_mb": {
      "type": "number",
      "minimum": 0
    },
    "swap_mb": {
      "type": "number",
      "minimum": 0
    },
    "memory_pressure": {
      "type": "string",
      "enum": ["green", "yellow", "red", "unknown"]
    },
    "compressed_memory_mb": {
      "type": "number",
      "minimum": 0
    },
    "latency_ms_per_token": {
      "type": "number",
      "minimum": 0
    },
    "tokens_per_second": {
      "type": "number",
      "minimum": 0
    },
    "benchmark": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": ["number", "string", "null"],
      "description": "Numeric score when available, otherwise a textual result or null."
    },
    "notes": {
      "type": "string"
    },
    "prompt_label": {
      "type": "string",
      "description": "Controlled prompt bucket, for example short, medium, or long."
    },
    "repeat_index": {
      "type": "integer",
      "minimum": 1
    },
    "target_prompt_tokens": {
      "type": "integer",
      "minimum": 1
    },
    "total_time_sec": {
      "type": "number",
      "minimum": 0
    },
    "start_swap_mb": {
      "type": "number",
      "minimum": 0
    },
    "end_swap_mb": {
      "type": "number",
      "minimum": 0
    },
    "swap_delta_mb": {
      "type": "number"
    },
    "memory_pressure_start": {
      "type": "string",
      "enum": ["green", "yellow", "red", "unknown"]
    },
    "memory_pressure_end": {
      "type": "string",
      "enum": ["green", "yellow", "red", "unknown"]
    },
    "memory_pressure_free_percent_start": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "memory_pressure_free_percent_end": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "compressed_memory_start_mb": {
      "type": "number",
      "minimum": 0
    },
    "compressed_memory_end_mb": {
      "type": "number",
      "minimum": 0
    },
    "thermal_throttling": {
      "type": "string",
      "enum": ["observed", "not_observed", "unknown"]
    },
    "telemetry_source": {
      "type": "string"
    },
    "start_unified_used_mb": {
      "type": "number"
    },
    "end_unified_used_mb": {
      "type": "number"
    },
    "unified_delta_mb": {
      "type": "number"
    },
    "peak_unified_used_mb": {
      "type": "number"
    },
    "start_unified_available_mb": {
      "type": "number"
    },
    "end_unified_available_mb": {
      "type": "number"
    },
    "start_process_rss_mb": {
      "type": "number"
    },
    "end_process_rss_mb": {
      "type": "number"
    },
    "peak_process_rss_mb": {
      "type": "number"
    },
    "peak_swap_mb": {
      "type": "number"
    },
    "start_compressor_mb": {
      "type": "number"
    },
    "end_compressor_mb": {
      "type": "number"
    },
    "peak_compressor_mb": {
      "type": "number"
    },
    "compressed_memory_delta_mb": {
      "type": "number"
    },
    "pageout_delta": {
      "type": "number"
    },
    "swapout_delta": {
      "type": "number"
    },
    "operating_regime_target": {
      "type": "string",
      "enum": ["under_saturated", "saturation", "contention", "unknown"]
    },
    "operating_regime_observed": {
      "type": "string",
      "enum": ["under_saturated", "saturation", "contention", "unknown"]
    },
    "pressure_injection": {
      "type": "string"
    },
    "selected_action": {
      "type": ["string", "null"]
    },
    "retention_ratio": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "kv_bits": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "estimated_full_kv_mb": {
      "type": "number",
      "minimum": 0
    },
    "estimated_kv_cache_mb": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "memory_budget_mb": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "backend_status": {
      "type": ["string", "null"],
      "enum": ["real", "simulated", "infeasible", null]
    },
    "policy_costs": {
      "type": ["array", "null"]
    },
    "latency_p95_ms_per_token": {
      "type": "number",
      "minimum": 0
    }
  }
}
